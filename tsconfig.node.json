{
  "compilerOptions": {
    "composite": true, // <-- ADICIONE ESTA LINHA
    "tsBuildInfoFile": "./node_modules/.dottsbuildinfo",
    "target": "ESNext",
    "lib": ["ESNext"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true
  },
  "include": ["vite.config.ts"]
}